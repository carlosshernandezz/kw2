POSTGRES_DB=kw2
POSTGRES_USER=kw2_app
POSTGRES_PASSWORD=replace_with_a_long_random_password
POSTGRES_PORT=5432
# Local por defecto: host 127.0.0.1. En Vercel/cloud usa DATABASE_URL.
# POSTGRES_HOST=127.0.0.1
# DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
# DATABASE_SSL=true

# Login básico de la app web. Formato: usuario:password,usuario2:password2
# Dejar vacío/desconfigurado desactiva el login, útil solo en desarrollo local.
KW2_BASIC_AUTH_USERS=carlos:replace_with_password,jose:replace_with_password

# WhatsApp Cloud API. Nunca guardes valores reales en este archivo.
WHATSAPP_VERIFY_TOKEN=replace_with_a_random_webhook_token
WHATSAPP_APP_SECRET=replace_with_meta_app_secret
WHATSAPP_ACCESS_TOKEN=replace_with_meta_system_user_token
WHATSAPP_GRAPH_VERSION=v23.0
# Opcional; por defecto usa data/whatsapp fuera del árbol público de la app.
# WHATSAPP_MEDIA_DIR=/absolute/private/path
